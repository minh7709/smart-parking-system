# =========================
# GLOBAL ENV - SMART PARKING
# Used by docker compose at project root
# =========================

# -------- Development (docker-compose.dev.yml) --------
DB_USER=admin
DB_PASS=dev_password_123

# -------- Production (docker-compose.prod.yml) --------
PROD_DB_USER=admin_prod
PROD_DB_PASS=change_me_prod_db_password
PROD_JWT_SECRET=change_me_to_a_long_random_secret_min_64_chars

# -------- Backend --------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/parking_db
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=dev_password_123
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
JWT_SECRET=change_me_to_a_long_random_secret_min_64_chars
AI_SERVICE_URL=http://ai-service:8000/api/v1/ai/detect-plate

# -------- AI Service --------
MODEL_PATH=/app/models/license_plate_detector.onnx
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# -------- Frontend --------
VITE_API_BASE_URL=http://localhost:8080

# -------- Common --------
TZ=Asia/Ho_Chi_Minh
